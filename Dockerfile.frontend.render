# Frontend Dockerfile for Vue 3 + Vite app (TradingAgents-CN)
# Optimized for Render deployment

# Build stage
FROM node:22-alpine AS build

ARG VITE_API_BASE_URL=""
ENV NODE_ENV=production
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}
WORKDIR /app/frontend

RUN corepack enable && corepack prepare yarn@1.22.22 --activate

COPY frontend/package.json frontend/yarn.lock frontend/.yarnrc ./
RUN yarn install --frozen-lockfile --production=false --network-timeout 300000

COPY frontend/. ./
COPY assets /app/frontend/public/assets
COPY docs /app/docs

RUN yarn vite build

# Runtime stage
FROM nginx:alpine AS runtime

WORKDIR /usr/share/nginx/html

COPY --from=build /app/frontend/dist .

# Copy nginx config template
COPY docker/nginx.render.conf /etc/nginx/conf.d/default.conf.template

# Create startup script
RUN printf '#!/bin/sh\n\
BACKEND_URL="${BACKEND_URL:-http://localhost:8000}"\n\
sed "s|__BACKEND_URL__|${BACKEND_URL}|g" /etc/nginx/conf.d/default.conf.template > /etc/nginx/conf.d/default.conf\n\
exec nginx -g "daemon off;"\n' > /docker-entrypoint-custom.sh && chmod +x /docker-entrypoint-custom.sh

ENV BACKEND_URL="http://localhost:8000"

EXPOSE 80

CMD ["/docker-entrypoint-custom.sh"]
