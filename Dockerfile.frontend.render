# Frontend Dockerfile for Vue 3 + Vite app (TradingAgents-CN)
# Optimized for Render deployment (US servers)

# Build stage
FROM node:22-alpine AS build

ENV NODE_ENV=production
WORKDIR /app/frontend

# Enable Corepack and use Yarn
RUN corepack enable && corepack prepare yarn@1.22.22 --activate

# Copy package files
COPY frontend/package.json frontend/yarn.lock frontend/.yarnrc ./

# Install dependencies
RUN yarn install --frozen-lockfile --production=false --network-timeout 300000

# Copy frontend source
COPY frontend/. ./

# Copy static assets
COPY assets /app/frontend/public/assets
COPY docs /app/docs

# Build production version
RUN yarn vite build

# Runtime stage
FROM nginx:alpine AS runtime

WORKDIR /usr/share/nginx/html

# Copy build output
COPY --from=build /app/frontend/dist .

# Copy nginx config template (uses ${BACKEND_URL} placeholder)
COPY docker/nginx.render.conf /etc/nginx/templates/default.conf.template

# Set default BACKEND_URL (will be overridden by Render env var)
ENV BACKEND_URL="http://localhost:8000"

# Expose port 80
EXPOSE 80

# nginx:alpine supports /etc/nginx/templates/ with envsubst automatically
# The entrypoint script in nginx:alpine runs envsubst on templates
CMD ["nginx", "-g", "daemon off;"]
