# Backend Dockerfile for FastAPI service (TradingAgents-CN)
# Optimized for Render deployment (US servers, free tier)

FROM python:3.10-slim-bookworm

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    TZ=Asia/Shanghai

WORKDIR /app

# Install system dependencies from standard repos (no Chinese mirrors)
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        fontconfig \
        fonts-noto-cjk \
        pandoc && \
    rm -rf /var/lib/apt/lists/*

# Copy project files needed for pip install
COPY pyproject.toml README.md ./

# Install Python dependencies (standard PyPI, no Chinese mirrors)
RUN pip install --upgrade pip && \
    pip install --prefer-binary . 2>&1 || \
    pip install --prefer-binary --no-deps . && \
    pip install fastapi uvicorn pydantic pydantic-settings motor pymongo redis \
        PyJWT bcrypt apscheduler aiofiles httpx sse-starlette \
        akshare pandas plotly python-dotenv rich toml tqdm \
        requests curl-cffi feedparser parsel praw \
        langchain-core langchain-openai langgraph openai \
        chainlit markdown pypandoc python-docx streamlit psutil

# Copy application code
COPY app ./app
COPY tradingagents ./tradingagents
COPY config ./config
COPY scripts ./scripts

# Copy Render-specific startup script
COPY scripts/startup_init_render.sh /app/scripts/startup_init.sh
RUN chmod +x /app/scripts/startup_init.sh

EXPOSE 8000

ENV DOCKER_CONTAINER=true

CMD ["/app/scripts/startup_init.sh"]
